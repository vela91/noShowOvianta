# Base de datos (opcional — sin esta variable la app funciona con datos vacíos)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# Anthropic API (opcional — sin esta variable se usa modo demo con respuestas simuladas)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs TTS (opcional — si no se configura, el botón "Escuchar llamada" no aparece)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
NEXT_PUBLIC_ELEVENLABS_ENABLED=false

# Autenticación de demo
DEMO_PASSWORD=cambia_esto
SESSION_SECRET=genera_un_secreto_aleatorio_aqui
